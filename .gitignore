# ============================================================
# Dog Haven Project - .gitignore
# ============================================================
# Place this file in the ROOT of your project (doghaven folder)

# ============================================================
# ENVIRONMENT VARIABLES (IMPORTANT - DO NOT COMMIT!)
# ============================================================
.env
.env.local
.env.development
.env.production
.env.test
*.env

# ============================================================
# NODE MODULES
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ============================================================
# BUILD OUTPUT
# ============================================================
dist/
dist-ssr/
build/
*.local

# ============================================================
# LOGS
# ============================================================
logs/
*.log
pids/
*.pid
*.seed
*.pid.lock

# ============================================================
# OPERATING SYSTEM FILES
# ============================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory
.Trash-*

# ============================================================
# IDE / EDITOR FILES
# ============================================================
# VSCode
.vscode/
!.vscode/extensions.json
*.code-workspace

# JetBrains (WebStorm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-workspace
*.sublime-project

# Vim
*.swp
*.swo
*~
.*.sw?

# Emacs
*~
\#*\#
.\#*

# ============================================================
# TESTING
# ============================================================
coverage/
*.lcov
.nyc_output

# ============================================================
# TEMPORARY FILES
# ============================================================
tmp/
temp/
*.tmp
*.bak
*.cache

# ============================================================
# DATABASE FILES (if using local SQLite for testing)
# ============================================================
*.sqlite
*.sqlite3
*.db

# ============================================================
# MISC
# ============================================================
.cache/
.parcel-cache/
.npm
.eslintcache
.node_repl_history
*.tgz
.yarn-integrity

# ============================================================
# PROJECT-SPECIFIC
# ============================================================
# Ignore any local database dumps you might create for testing
*.sql.backup
dump.sql

# Ignore any local configuration files
config.local.js

